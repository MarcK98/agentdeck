{
  "name": "claude-channel-bridge",
  "version": "0.1.0",
  "description": "Local Node server that watches chat channels (Discord, and more) and forwards messages to Claude Code, replying with its output.",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node scripts/dev.js",
    "dev:plain": "node --watch src/index.js",
    "dashboard": "node src/dashboard.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@lydell/node-pty": "^1.2.0-beta.12",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@xterm/headless": "^6.0.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5",
    "zod": "^3.24.1"
  }
}
