{
  "name": "spawn-monorepo",
  "version": "0.1.0",
  "description": "Spawn (spawnmy.ai) — a mastermind for Claude. Monorepo: @spawn/core (daemon + orchestration + legacy Discord bridge) and @spawn/desktop (Electron client).",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "node src/index.js",
    "dev": "node packages/core/scripts/dev.js",
    "dev:plain": "node --watch src/index.js",
    "dashboard": "node packages/core/src/dashboard.js",
    "desktop": "npm run dev -w @spawn/desktop",
    "daemon": "node packages/core/src/daemon/server.js"
  },
  "engines": {
    "node": ">=20"
  }
}
