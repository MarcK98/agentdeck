{
  "name": "@spawn/core",
  "version": "0.1.0",
  "description": "Spawn core — a mastermind for Claude: session orchestration, projects, team lead, approvals, usage, SQLite store, and the Spawn daemon. Also hosts the legacy Discord bridge.",
  "type": "module",
  "main": "src/daemon/index.js",
  "exports": {
    ".": "./src/daemon/index.js",
    "./daemon-server": "./src/daemon/server.js",
    "./bridge": "./src/index.js",
    "./db": "./src/db/index.js",
    "./config": "./src/config.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "start": "node src/index.js",
    "dashboard": "node src/dashboard.js",
    "daemon": "node src/daemon/server.js",
    "test": "node --test --experimental-test-module-mocks 'src/**/*.test.js'"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@lydell/node-pty": "^1.2.0-beta.12",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@xterm/headless": "^6.0.0",
    "better-sqlite3": "^12.2.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5",
    "zod": "^3.24.1",
    "ws": "^8.18.0"
  }
}
