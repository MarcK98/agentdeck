# ── Which channels to start (comma-separated) ──────────────────────────────
# Supported: discord   (telegram, slack, etc. can be added as new adapters)
CHANNELS=discord

# ── Discord ────────────────────────────────────────────────────────────────
# Create a bot at https://discord.com/developers/applications
#   - Enable the "MESSAGE CONTENT INTENT" under Bot settings
#   - Invite it to your server with the "bot" scope + Send Messages / Read History perms
DISCORD_BOT_TOKEN=

# Optional: only respond in these channel IDs (comma-separated). Empty = all channels.
DISCORD_ALLOWED_CHANNELS=
# Require the bot to be @mentioned before it responds (true/false).
# Recommended true in busy servers so it doesn't reply to every message.
DISCORD_REQUIRE_MENTION=true

# ── Projects (per-channel working directories) ─────────────────────────────
# A channel named "my-app" runs Claude in <PROJECTS_ROOT>/my-app.
# Each project folder carries its own CLAUDE.md, .mcp.json, .claude/skills,
# and chat history. Channels with no matching folder are ignored.
PROJECTS_ROOT=/Users/mkhoury/Documents
# Fallback project for DMs and unmapped channels. Empty = ignore them.
DEFAULT_PROJECT=
# For explicit channel->folder mapping, create projects.json (see README).

# ── Claude Code bridge ─────────────────────────────────────────────────────
# Path to the claude executable (leave as "claude" if it's on your PATH).
CLAUDE_BIN=claude
# Fallback working directory if no project resolves. Defaults to CWD.
CLAUDE_CWD=
# Optional model override, e.g. claude-sonnet-5 or an alias (opus/sonnet/haiku).
# Empty = your CLI default. Never default this to `fable` — reserve it for when
# Marc explicitly asks.
CLAUDE_MODEL=
# Default reasoning effort for every run: low | medium | high | xhigh | max.
# Empty = CLI default. Per-run overrides (team-lead heartbeat, delegated tasks)
# take precedence over this.
CLAUDE_EFFORT=
# Auto-reset a channel's session once a single run's context passes this many
# tokens — bounds cost and stays clear of the model window. 0 = off (grow until
# the model's own window, ~200k for haiku/opus). The team lead uses its own,
# higher cap below. Keep this under the model window unless you enable 1M (below).
CLAUDE_MAX_CONTEXT_TOKENS=0
# Beta headers sent on every request (comma/space-separated). To unlock Sonnet's
# 1M-token context window, set: CLAUDE_BETAS=context-1m-2025-08-07 (and use a
# Sonnet model + raise the *_MAX_CONTEXT_TOKENS caps accordingly).
CLAUDE_BETAS=
# Keep conversation context per channel using --resume (true/false).
CLAUDE_PERSIST_SESSIONS=true
# Auto-approval: empty = ask on Discord for everything not allowed by the
# project's .claude/settings.json rules.
#   acceptEdits        = auto-approve file edits, still ask for commands
#   bypassPermissions  = auto-approve EVERYTHING (dangerous, no prompts)
CLAUDE_PERMISSION_MODE=
# Extra flags passed verbatim to the CLI, space-separated. Advanced use only.
# e.g. --allowedTools "Read,Grep"   or   --permission-mode plan
CLAUDE_EXTRA_ARGS=
# Idle timeout: max seconds Claude may go silent BETWEEN actions before the run
# is killed. Approval waits don't count (the clock pauses for them).
CLAUDE_TIMEOUT_SECONDS=900
# Tool timeout: max seconds a single running tool (build, test suite,
# `gh run watch`, a CI poll, …) may work with no output. Raise this if Claude
# waits on long CI/builds. A busy tool emits nothing, so the idle timeout above
# does not apply while one is running.
CLAUDE_TOOL_TIMEOUT_SECONDS=1800

# ── Attachments ────────────────────────────────────────────────────────────
# Download files attached to a message into a temp folder and let Claude read
# them (images, PDFs, code, text, …). Set false to ignore attachments.
ATTACHMENTS_ENABLED=true
# Skip any single attachment larger than this many megabytes. Also caps the size
# of files agents upload back to Discord via the share_file tool.
ATTACHMENT_MAX_MB=25
# Agents share files back to Discord with the share_file tool. By default they may
# upload from the channel's own project dir, PROJECTS_ROOT, DEFAULT_PROJECT, and
# the temp dir. Add extra absolute dirs here (comma-separated) to allow more,
# e.g. /Users/you/Desktop.
SHARE_ALLOWED_DIRS=

# ── Live progress ──────────────────────────────────────────────────────────
# Post a status message that updates in place with the tool Claude is currently
# running (handy for long CI waits / multi-step work). Removed when the run ends.
PROGRESS_ENABLED=true

# ── Sticky control bar ─────────────────────────────────────────────────────
# An always-visible message with buttons — Reset context / Stop (and Pause·Resume
# in the team-lead channel) — kept at the bottom of the channel, re-posted after
# activity. The Reset button clears that channel's Claude session (like /reset).
CONTROLS_ENABLED=false
# Channel names/ids to show it in (comma-separated). Empty = the team-lead channel.
CONTROL_CHANNELS=

# ── Terminal mode (interactive commands) ───────────────────────────────────
# Commands like /workflows need a real terminal. When enabled, they open a live
# PTY Claude session rendered into Discord (drive it with buttons + messages,
# /exit to leave). Needs @lydell/node-pty and @xterm/headless (already deps).
TERMINAL_ENABLED=true
# Comma-separated commands that open terminal mode (/terminal always works).
TERMINAL_TRIGGERS=/workflows
# Auto-close a terminal after this many seconds with no output or input.
TERMINAL_IDLE_SECONDS=3600
# Permission mode for terminal sessions: bypassPermissions | acceptEdits | default.
# Empty = inherit CLAUDE_PERMISSION_MODE. Set bypassPermissions to skip all
# approval prompts inside the live terminal (like the -p runs do).
TERMINAL_PERMISSION_MODE=

# ── PR review loop ─────────────────────────────────────────────────────────
# The #pr-reviewer channel (id or name). When an agent opens a PR and calls the
# notify_pr_reviewer tool, the bridge opens a thread here and runs the reviewer;
# requested changes route back to the author agent. Empty = feature off.
PR_REVIEWER_CHANNEL=pr-reviewer
# Merge method used after you approve in the thread: squash | merge | rebase.
PR_MERGE_METHOD=squash
# Give up (ask a human) after this many review<->fix rounds on one PR.
PR_MAX_ROUNDS=5

# ── Team lead (always-on orchestrator) ─────────────────────────────────────
# A dedicated channel whose agent stays on: a heartbeat wakes it to check its
# task board (TASKS.md), delegate coding to project channels, and @mention you
# when it needs a decision. Empty = feature off.
TEAMLEAD_CHANNEL=
# How often the heartbeat ticks (minutes). Each tick is a full run — mind cost.
TEAMLEAD_INTERVAL_MINUTES=30
# Safety cap on ticks per day.
TEAMLEAD_MAX_TICKS_PER_DAY=60
# Model for the team lead — used for BOTH the heartbeat tick and your interactive
# messages in the channel (they share one session, so they must match). A tick is
# lightweight, so a cheap model like `haiku` keeps ticks cheap; use `sonnet` if you
# want the 1M window (see TEAMLEAD_BETAS). Empty = CLI default.
TEAMLEAD_MODEL=haiku
# Beta headers for team-lead runs ONLY (not other channels). Sonnet's 1M window
# would be TEAMLEAD_BETAS=context-1m-2025-08-07 + TEAMLEAD_CONTEXT_WINDOW=1000000 —
# BUT the Claude Code CLI ignores --betas on a Claude subscription/Max login
# ("Custom betas are only available for API key users"). So 1M only works if you
# run the bridge with an ANTHROPIC_API_KEY (pay-per-token). On a subscription,
# leave this empty; a Sonnet team lead still runs at ~200k.
TEAMLEAD_BETAS=
# The team lead's model context window (tokens) — drives the "near the window"
# warning. ~200k for haiku/opus/sonnet default; 1000000 with the 1M beta above.
TEAMLEAD_CONTEXT_WINDOW=200000
# Reasoning effort for the heartbeat tick: low | medium | high | xhigh | max.
# Ticks are routine checks, so `low` is plenty. The team lead escalates by
# delegating heavy work with a higher per-task model/effort.
TEAMLEAD_EFFORT=low
# Team-lead context handling. 0 = never auto-reset (warn-only): the team lead
# posts a heads-up as its context climbs instead of resetting, so you /reset it
# on your own terms. Set a non-zero cap to ALSO hard-reset past it (keep under
# the model window, ~200k on haiku; for more, use a Sonnet model + CLAUDE_BETAS).
TEAMLEAD_MAX_CONTEXT_TOKENS=0
# How often (in tokens of growth) the team lead warns you about its context size.
# Smaller = more frequent warnings. e.g. 20000 warns at ~20k, 40k, 60k, …
TEAMLEAD_CONTEXT_WARN_EVERY=20000
# Your Discord numeric user ID so it can really @mention (ping) you. Optional —
# the bridge auto-learns it the first time you post in the team-lead channel.
OWNER_DISCORD_ID=

# ── VPN control (Tunnelblick, macOS) ───────────────────────────────────────
# Lets agents (mainly the team lead) toggle the Tunnelblick VPN via the `vpn` MCP
# tool, to bring it up when a channel needs the VPN to reach its backend/database/
# services. Off unless enabled.
VPN_CONTROL_ENABLED=false
# Default Tunnelblick configuration name when a `vpn` call omits one.
TUNNELBLICK_CONFIG=
# Comma-separated allowlist of config names an agent may toggle (empty = any).
VPN_ALLOWED_CONFIGS=
# Setup notes:
#  - Grant the bridge's terminal/node binary Automation control of Tunnelblick
#    (System Settings > Privacy & Security > Automation) — first attempt prompts.
#  - Configure the VPN config to connect/disconnect WITHOUT an admin password
#    (Tunnelblick per-config setting), else automated connect will stall on a prompt.

# ── Trello board sync (team lead) ──────────────────────────────────────────
# Mirror the team lead's TASKS.md to a Trello board (one card per task, filed in
# the list that matches its status) and surface Marc's board changes (card
# moves/adds/comments) back to the team lead. Off unless enabled.
TRELLO_ENABLED=false
# API key + token: https://trello.com/power-ups/admin -> your Power-Up -> API Key
# tab (copy the key, then the "Token" link to authorize and copy the token).
TRELLO_API_KEY=
TRELLO_TOKEN=
# API secret (same Power-Up page as the key). Required if you set a webhook
# callback URL below: incoming webhook POSTs are HMAC-verified against it, and
# unverifiable POSTs are rejected. Not needed for poll-only mode.
TRELLO_API_SECRET=
# Board short id (from the board URL trello.com/b/<SHORT_ID>/...) or the long id.
TRELLO_BOARD_ID=
# Task status -> board list name. Missing lists are created automatically.
TRELLO_LIST_TODO=To Do
TRELLO_LIST_IN_PROGRESS=In Progress
TRELLO_LIST_BLOCKED=Blocked for Marc
TRELLO_LIST_IN_REVIEW=In Review
TRELLO_LIST_DONE=Done
# How often (seconds) to poll the board for Marc's changes.
TRELLO_POLL_SECONDS=120
# Real-time push instead of/alongside polling: a PUBLIC HTTPS URL Trello POSTs
# card events to (e.g. an ngrok/Cloudflare tunnel to TRELLO_WEBHOOK_PORT).
# Empty = poll only. The endpoint must answer Trello's HEAD validation with 200.
TRELLO_WEBHOOK_CALLBACK_URL=
TRELLO_WEBHOOK_PORT=8792
# Wake the team lead immediately on a board change (costs a run). Off = fold the
# change into the next scheduled heartbeat tick (cheaper — respects the budget).
TRELLO_NUDGE_ON_CHANGE=false

# ── Browser access (chrome-devtools-mcp) ───────────────────────────────────
# Gives agents Chrome via Google's chrome-devtools-mcp (launched with npx), so
# they can drive a browser without you switching to /terminal. Off unless enabled.
BROWSER_MCP_ENABLED=false
# Attach to an already-running Chrome over CDP to keep your logged-in sessions /
# auth-gated backends. Launch Chrome with --remote-debugging-port=9222, then set
# this to http://127.0.0.1:9222. Empty = the MCP launches & manages its own Chrome.
BROWSER_MCP_URL=
# When the MCP launches its own Chrome: release channel (stable|canary|beta|dev).
BROWSER_MCP_CHANNEL=
# Run that launched Chrome headless (ignored when BROWSER_MCP_URL is set).
BROWSER_MCP_HEADLESS=false
# Use a throwaway profile instead of the persistent one (no saved logins).
BROWSER_MCP_ISOLATED=false
# Setup notes:
#  - Needs npx on PATH and Chrome installed; first run npx-downloads the server.
#  - Tools appear to agents as mcp__chrome-devtools__* (navigate, click, etc.).

# ── Token-usage alert ──────────────────────────────────────────────────────
# When a channel's session context grows past this many tokens, the bridge
# @mentions the owner in that channel with Reset / Keep buttons (Reset = /reset
# into a fresh session). 0 disables.
SESSION_TOKEN_ALERT=500000

# ── Approvals (Claude permission prompts on Discord) ───────────────────────
# When Claude wants to run a command / edit a file, post Allow/Deny buttons
# in the channel instead of auto-denying.
APPROVALS_ENABLED=true
# Local port for the approval bridge (only listens on 127.0.0.1).
APPROVAL_PORT=8790
# Seconds before an unanswered approval prompt auto-denies.
APPROVAL_TIMEOUT_SECONDS=300

# ── Usage dashboard (npm run dashboard) ────────────────────────────────────
# Local analytics on token usage per model / channel / team-lead / day / hour,
# plus rolling-window gauges to help you stay within the Max plan. Reads the
# usage ledger (usage.jsonl, written on every run) + Claude Code's own JSONL
# logs. Serves on http://localhost:<port> (127.0.0.1 only).
DASHBOARD_PORT=8791
# Days of Claude Code history to scan for the account-wide view.
DASHBOARD_BACKFILL_DAYS=30
# "Stay within plan" soft ceilings. Max x20 publishes no token cap (dynamic 5h
# + weekly limits), so set your own from observed usage — the gauges warn as a
# window approaches these. USD is equivalent-cost (see src/pricing.js).
# 0 = hide that gauge's limit line (show usage only).
DASHBOARD_LIMIT_USD_5H=0
DASHBOARD_LIMIT_USD_7D=0
DASHBOARD_LIMIT_TOKENS_5H=0
DASHBOARD_LIMIT_TOKENS_7D=0

# ── AgentDeck monorepo ────────────────────────────────────────────────────────────
# Where runtime state lives (sessions.json, usage.jsonl, projects.json, agentdeck.db).
# Default: the repo root. The desktop app and bridge share this.
# SPAWN_DATA_DIR=
# AgentDeck daemon (separate background process; desktop auto-starts it)
# SPAWN_DAEMON_PORT=8791
# Node binary used when the desktop app auto-starts the daemon
# SPAWN_NODE_BIN=/opt/homebrew/bin/node
